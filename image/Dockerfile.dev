ARG OAUTH2_POXY_VERSION=v7.15.2
ARG NODE_VERSION=26-alpine
ARG GO_VERSION=1.26.3-alpine

# Go toolchain as a named stage. BuildKit forbids variable expansion in
# `COPY --from=<expr>`; a FROM using a global-scope ARG is the supported
# workaround, so we name the golang stage and `COPY --from=gobuild` below.
FROM golang:${GO_VERSION} AS gobuild

FROM quay.io/oauth2-proxy/oauth2-proxy:${OAUTH2_POXY_VERSION}-alpine
ARG GO_VERSION

# Pin Go to a specific version regardless of what's in the Alpine repo
# attached to the oauth2-proxy base. The toolchain is copied from the
# official golang image; bumping the tag below bumps the Go version
# used in this dev container.
COPY --from=gobuild /usr/local/go /usr/local/go
ENV PATH="/usr/local/go/bin:${PATH}"

RUN apk update && apk add --no-cache \
    ca-certificates bash python3 py3-pip gzip fuse fuse3 s3fs-fuse \
    nodejs npm git build-base \
    && rm -rf /var/cache/apk/*
COPY ./image/USERTrust_RSA_Certification_Authority.pem /usr/local/share/ca-certificates/USERTrust_RSA_Certification_Authority.pem
RUN update-ca-certificates

RUN python3 -m pip install --no-cache-dir --break-system-packages --upgrade pip && \
    python3 -m pip install --no-cache-dir --break-system-packages rdflib==7.5.0 chardet==5.2.0 datasketch==1.9.0 python-dateutil==2.9.0.post0

ARG USER_ID
ARG GROUP_ID
RUN addgroup --gid ${GROUP_ID} app \
 && adduser --disabled-password --uid ${USER_ID} --ingroup app --gecos '' app

COPY ./image/cdi_generator_jsonld.py /usr/local/bin/cdi_generator_jsonld.py
COPY ./xconvert /usr/local/bin/xconvert
RUN chmod +x /usr/local/bin/cdi_generator_jsonld.py /usr/local/bin/xconvert

ENV GOPATH=/home/app/go
ENV GO111MODULE=on
ENV PATH="$GOPATH/bin:/home/app/go/bin:/root/go/bin:$PATH"

RUN mkdir -p /home/app/go/bin /home/app/go/pkg /home/app/.cache/go-build \
    && chown -R app:app /home/app/go /home/app/.cache

WORKDIR /workspace/backend
COPY ./image /workspace/backend

COPY ./image/dev-entrypoint.sh /usr/local/bin/dev-entrypoint.sh
RUN chmod +x /usr/local/bin/dev-entrypoint.sh

USER app

ENV DEV="true"

ENTRYPOINT ["/usr/local/bin/dev-entrypoint.sh"]
